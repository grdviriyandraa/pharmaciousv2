// AMERTA Smart Quality Gate — data model (PRD §9)
// Dev uses SQLite. To move to MySQL/Postgres: change `provider` + DATABASE_URL,
// then `prisma migrate dev`. No app code changes needed (Prisma abstracts it).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Supplier {
  id             String   @id
  name           String
  ingredient     String // "mangosteen" | "kelor" | "pegagan"
  region         String
  specCompliance Float
  rating         Int
  status         String // "active" | "probation" | "pending"
  batches        Batch[]
}

model Batch {
  id            String    @id
  ingredient    String
  supplierId    String
  supplier      Supplier  @relation(fields: [supplierId], references: [id])
  region        String
  receivedAt    DateTime
  quantityKg    Int
  cvGrade       String? // mangosteen only
  cvConfidence  Float?
  nirMarkerPct  Float?
  markerSpecMin Float
  gateDecision  String // "accept" | "route_nir" | "reject"
  createdAt     DateTime  @default(now())
}

model User {
  id           String @id @default(cuid())
  email        String @unique
  name         String
  role         String // "qc" | "qa" | "production_manager"
  passwordHash String // PBKDF2 (lib/auth.ts) — di-seed dgn kata sandi demo
}
