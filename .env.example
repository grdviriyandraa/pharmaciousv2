# Salin ke .env (lokal) atau isi sebagai Environment Variables di Vercel.

# Database.
#  - Lokal (dev sekarang): SQLite.
#      DATABASE_URL="file:./dev.db"
#  - Produksi/Vercel: Postgres (Neon/Supabase). Contoh Neon:
#      DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
DATABASE_URL="file:./dev.db"

# Rahasia sesi login (WAJIB di produksi — auth.ts melempar error kalau kosong).
# Generate baru: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="ganti-dengan-nilai-acak-32-byte"
